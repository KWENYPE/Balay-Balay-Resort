@model BalayBalayResort.ViewModels.AdminDashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
    Layout = "_AdminLayout";
}

<h1 class="admin-page-title">Dashboard Overview</h1>

<!-- Stat Cards -->
<div class="admin-stats-grid">

    <div class="admin-stat-card">
        <div class="admin-stat-icon icon-blue">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="currentColor" viewBox="0 0 16 16">
                <path d="M15 14s1 0 1-1-1-4-5-4-5 3-5 4 1 1 1 1h8zm-7.978-1A.261.261 0 0 1 7 12.996c.001-.264.167-1.03.76-1.72C8.312 10.629 9.282 10 11 10c1.717 0 2.687.63 3.24 1.276.593.69.758 1.457.76 1.72l-.008.002-.014.002H7.022zM11 7a2 2 0 1 0 0-4 2 2 0 0 0 0 4zm3-2a3 3 0 1 1-6 0 3 3 0 0 1 6 0zM6.936 9.28a5.88 5.88 0 0 0-1.23-.247A7.35 7.35 0 0 0 5 9c-4 0-5 3-5 4 0 .667.333 1 1 1h4.216A2.238 2.238 0 0 1 5 13c0-1.01.377-2.042 1.09-2.904.243-.294.526-.569.846-.816zM4.92 10A5.493 5.493 0 0 0 4 13H1c0-.26.164-1.03.76-1.724.545-.636 1.492-1.256 3.16-1.275zM1.5 5.5a3 3 0 1 1 6 0 3 3 0 0 1-6 0zm3-2a2 2 0 1 0 0 4 2 2 0 0 0 0-4z"/>
            </svg>
        </div>
        <div class="admin-stat-info">
            <div class="admin-stat-label">Total Users</div>
            <div class="admin-stat-value">@Model.TotalUsers</div>
        </div>
    </div>

    <div class="admin-stat-card">
        <div class="admin-stat-icon icon-purple">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="currentColor" viewBox="0 0 16 16">
                <path d="M8.354 1.146a.5.5 0 0 0-.708 0l-6 6A.5.5 0 0 0 1.5 7.5v7a.5.5 0 0 0 .5.5h4.5a.5.5 0 0 0 .5-.5v-4h2v4a.5.5 0 0 0 .5.5H14a.5.5 0 0 0 .5-.5v-7a.5.5 0 0 0-.146-.354L13 5.793V2.5a.5.5 0 0 0-.5-.5h-1a.5.5 0 0 0-.5.5v1.293L8.354 1.146z"/>
            </svg>
        </div>
        <div class="admin-stat-info">
            <div class="admin-stat-label">Properties</div>
            <div class="admin-stat-value">@Model.TotalProperties</div>
        </div>
    </div>

    <div class="admin-stat-card">
        <div class="admin-stat-icon icon-green">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="currentColor" viewBox="0 0 16 16">
                <path d="M3.5 0a.5.5 0 0 1 .5.5V1h8V.5a.5.5 0 0 1 1 0V1h1a2 2 0 0 1 2 2v11a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2V3a2 2 0 0 1 2-2h1V.5a.5.5 0 0 1 .5-.5zM1 4v10a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1V4H1z"/>
            </svg>
        </div>
        <div class="admin-stat-info">
            <div class="admin-stat-label">Active Bookings</div>
            <div class="admin-stat-value">@Model.ActiveBookings</div>
        </div>
    </div>

    <div class="admin-stat-card">
        <div class="admin-stat-icon icon-amber">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="currentColor" viewBox="0 0 16 16">
                <path d="M0 4a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2V4zm2-1a1 1 0 0 0-1 1v1h14V4a1 1 0 0 0-1-1H2zm13 4H1v5a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1V7z"/>
                <path d="M2 10a1 1 0 0 1 1-1h1a1 1 0 0 1 1 1v1a1 1 0 0 1-1 1H3a1 1 0 0 1-1-1v-1z"/>
            </svg>
        </div>
        <div class="admin-stat-info">
            <div class="admin-stat-label">Total Revenue</div>
            <div class="admin-stat-value">&#8369;@Model.TotalRevenue.ToString("N0")</div>
        </div>
    </div>

</div>

<!-- Recent Bookings + Transactions -->
<div class="admin-tables-grid">

    <!-- Recent Bookings -->
    <div class="admin-table-card">
        <h2 class="admin-table-title">Recent Bookings</h2>
        @foreach (var b in Model.RecentBookings)
        {
            <div class="admin-booking-row">
                <div class="admin-booking-info">
                    <div class="admin-booking-name">@b.PropertyName</div>
                    <div class="admin-booking-date">@b.Date</div>
                </div>
                <span class="admin-badge @b.Status.ToLower()">@b.Status</span>
            </div>
        }
    </div>

    <!-- Recent Transactions -->
    <div class="admin-table-card">
        <h2 class="admin-table-title">Recent Transactions</h2>
        @foreach (var t in Model.RecentTransactions)
        {
            <div class="admin-txn-row">
                <div class="admin-txn-left">
                    <div class="admin-txn-id">@t.TransactionId</div>
                    <div class="admin-txn-method">@t.PaymentMethod</div>
                </div>
                <div class="admin-txn-right">
                    <div class="admin-txn-amount">&#8369;@t.Amount.ToString("N0")</div>
                    <div class="admin-txn-date">@t.Date</div>
                </div>
            </div>
        }
    </div>

</div>
