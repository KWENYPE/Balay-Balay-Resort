@model Balay_Balay_Resort.Models.Property

@{
    ViewData["Title"] = "Complete Your Booking";
    Layout = "_DashboardLayout";

    var imagePath = string.IsNullOrWhiteSpace(Model.PropertyImagePath)
        ? "/images/bg-login.png"
        : Model.PropertyImagePath;
}

<div class="booking-wrapper">

    <!-- Back Button -->
    <div class="booking-topbar">
        <a href="/property/@Model.Property_ID" class="detail-back-btn">← Back to Unit</a>
    </div>

    <h1 class="booking-main-title">Complete Your Booking</h1>

    <form method="post" action="/booking/@Model.Property_ID" id="bookingForm">
        @Html.AntiForgeryToken()

        <input type="hidden" name="Property_ID" value="@Model.Property_ID" />
        <input type="hidden" name="TotalAmount" id="TotalAmountInput" value="0" />

        <!-- Two Column Layout -->
        <div class="booking-layout">

            <!-- LEFT: Form -->
            <div class="booking-left">

                <!-- Hero Image -->
                <div class="booking-hero">
                    <img src="@imagePath" alt="@Model.Property_Name" class="booking-hero-img" />

                    <div class="booking-hero-overlay">
                        <p class="booking-hero-unit">Unit #@Model.UnitNumber</p>
                        <h2 class="booking-hero-name">@Model.Property_Name</h2>
                    </div>
                </div>

                <!-- Form Card -->
                <div class="booking-form-card">

                    <h3 class="booking-form-title">Select Dates</h3>

                    <div class="booking-dates-row">
                        <div class="booking-field">
                            <label class="booking-label">Check-in</label>
                            <input type="date"
                                   id="checkin"
                                   name="CheckInDate"
                                   class="booking-input"
                                   required />
                        </div>

                        <div class="booking-field">
                            <label class="booking-label">Check-out</label>
                            <input type="date"
                                   id="checkout"
                                   name="CheckOutDate"
                                   class="booking-input"
                                   required />
                        </div>
                    </div>

                    <div class="booking-field" style="margin-top:18px;">
                        <label class="booking-label">Number of Guests</label>

                        <input type="number"
                               id="guests"
                               name="NumberOfGuests"
                               class="booking-input"
                               value="1"
                               min="1"
                               max="@Model.GuestCapacity"
                               required />

                        <p class="booking-hint">Maximum @Model.GuestCapacity guest@(Model.GuestCapacity == 1 ? "" : "s")</p>
                    </div>

                    <button type="button" class="booking-check-btn" onclick="checkAvailability()">
                        Check Availability
                    </button>

                    <div class="booking-available" id="availMsg" style="display:none;">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="#2e7d32" viewBox="0 0 16 16">
                            <path d="M16 8A8 8 0 1 1 0 8a8 8 0 0 1 16 0zm-3.97-3.03a.75.75 0 0 0-1.08.022L7.477 9.417 5.384 7.323a.75.75 0 0 0-1.06 1.06L6.97 11.03a.75.75 0 0 0 1.079-.02l3.992-4.99a.75.75 0 0 0-.01-1.05z" />
                        </svg>

                        <div>
                            <strong>Available!</strong>
                            <p id="availText">This unit is available for your selected dates.</p>
                        </div>
                    </div>
                    <div class="booking-unavailable" id="unavailMsg" style="display:none;">
                        <strong>Not Available!</strong>
                        <p id="unavailText">This unit is not available for the selected dates.</p>
                    </div>

                </div>
            </div>

            <!-- RIGHT: Price Summary -->
            <div class="booking-right">
                <div class="booking-summary-card">
                    <h3 class="booking-summary-title">Price Summary</h3>

                    <div class="booking-summary-row">
                        <span class="booking-summary-label" id="nightsLabel">
                            ₱@Model.Amount.ToString("N0") x 0 nights
                        </span>
                        <span class="booking-summary-amount" id="nightsTotal">₱0</span>
                    </div>

                    <div class="booking-summary-row">
                        <span class="booking-summary-label">Service fee</span>
                        <span class="booking-summary-amount" id="serviceFee">₱0</span>
                    </div>

                    <div class="booking-summary-divider"></div>

                    <div class="booking-summary-row booking-total-row">
                        <span class="booking-total-label">Total</span>
                        <span class="booking-total-amount" id="totalAmount">₱0</span>
                    </div>

                    <button type="button" class="booking-proceed-btn" onclick="openPaymentModal()">
                        Proceed to Payment
                    </button>
                </div>
            </div>

        </div>

        <!-- PAYMENT MODAL -->
        <div class="modal fade" id="paymentModal" tabindex="-1" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content" style="border-radius:16px; border:none; padding:0; overflow:hidden;">

                    <div class="modal-header">
                        <h5 class="modal-title">Payment</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>

                    <div class="modal-body">
                        <div style="margin-bottom:14px;">
                            <strong>@Model.Property_Name</strong>
                            <p style="margin:4px 0 0; color:#6b7280;">Unit #@Model.UnitNumber</p>
                        </div>

                        <div style="display:flex; justify-content:space-between; margin-bottom:8px;">
                            <span>Total Amount</span>
                            <strong id="modalTotalAmount">₱0</strong>
                        </div>

                        <div class="booking-field" style="margin-top:18px;">
                            <label class="booking-label">Payment Method</label>
                            <select name="PaymentMode" id="PaymentMode" class="booking-input">
                                <option value="Cash">Cash</option>
                                <option value="GCash">GCash</option>
                                <option value="Bank Transfer">Bank Transfer</option>
                            </select>
                        </div>

                        <div class="booking-field" style="margin-top:18px;">
                            <label class="booking-label">Amount Given</label>
                            <input type="number"
                                   name="AmountGiven"
                                   id="AmountGiven"
                                   class="booking-input"
                                   min="0"
                                   value="0"
                                   oninput="computeChange()" />
                        </div>

                        <div style="display:flex; justify-content:space-between; margin-top:14px;">
                            <span>Change</span>
                            <strong id="changeAmount">₱0</strong>
                        </div>
                    </div>

                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                            Cancel
                        </button>

                        <button type="button"
                                onclick="validatePaymentBeforeSubmit()"
                                class="btn btn-primary"
                                style="background:#4b1f0e; border:none;">
                            Confirm Booking
                        </button>
                    </div>

                </div>
            </div>
        </div>

        <!-- VALIDATION MODAL -->
        <div class="modal fade" id="validationModal" tabindex="-1" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content" style="border-radius:16px; border:none; overflow:hidden;">
                    <div class="modal-header">
                        <h5 class="modal-title">Booking Notice</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>

                    <div class="modal-body">
                        <p id="validationMessage" style="margin:0; color:#374151; font-size:15px;"></p>
                    </div>

                    <div class="modal-footer">
                        <button type="button"
                                class="btn"
                                data-bs-dismiss="modal"
                                style="background:#4b1f0e; color:white; border-radius:8px; padding:8px 22px;">
                            OK
                        </button>
                    </div>
                </div>
            </div>
        </div>

    </form>
</div>

@section Scripts {
    <script>
        const pricePerNight = @Model.Amount;
        const serviceFee = 0;
        let currentTotal = 0;

        const checkin = document.getElementById('checkin');
        const checkout = document.getElementById('checkout');
        const guests = document.getElementById('guests');

        const nightsLabel = document.getElementById('nightsLabel');
        const nightsTotal = document.getElementById('nightsTotal');
        const totalAmount = document.getElementById('totalAmount');
        const totalAmountInput = document.getElementById('TotalAmountInput');
        const modalTotalAmount = document.getElementById('modalTotalAmount');
        const availMsg = document.getElementById('availMsg');
        const unavailMsg = document.getElementById('unavailMsg');
        const unavailText = document.getElementById('unavailText');
        const availText = document.getElementById('availText');

        function showValidationModal(message) {
            document.getElementById('validationMessage').textContent = message;

            const validationModal = new bootstrap.Modal(document.getElementById('validationModal'));
            validationModal.show();
        }

        const serverError = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(TempData["Error"]?.ToString() ?? ""));

        if (serverError) {
            document.addEventListener('DOMContentLoaded', function () {
                showValidationModal(serverError);
            });
        }

        function formatPeso(value) {
            return '₱' + Number(value).toLocaleString();
        }

        function resetTotal() {
            currentTotal = 0;
            nightsLabel.textContent = `${formatPeso(pricePerNight)} x 0 nights`;
            nightsTotal.textContent = '₱0';
            totalAmount.textContent = '₱0';
            totalAmountInput.value = 0;
            modalTotalAmount.textContent = '₱0';
        }

        function calculateBooking() {
            if (!checkin.value || !checkout.value) {
                resetTotal();
                return false;
            }

            const startDate = new Date(checkin.value);
            const endDate = new Date(checkout.value);

            if (endDate <= startDate) {
                resetTotal();
                return false;
            }

            const diffTime = endDate - startDate;
            const nights = Math.ceil(diffTime / (1000 * 60 * 60 * 24));
            const subtotal = pricePerNight * nights;

            currentTotal = subtotal + serviceFee;

            nightsLabel.textContent = `${formatPeso(pricePerNight)} x ${nights} night${nights !== 1 ? 's' : ''}`;
            nightsTotal.textContent = formatPeso(subtotal);
            totalAmount.textContent = formatPeso(currentTotal);
            totalAmountInput.value = currentTotal;
            modalTotalAmount.textContent = formatPeso(currentTotal);

            return true;
        }

        function validateGuestCount() {
            const guestCount = parseInt(guests.value);
            const maxGuests = @Model.GuestCapacity;

            if (isNaN(guestCount) || guestCount < 1) {
                showUnavailableMessage('Please enter at least 1 guest.');
                return false;
            }

            if (guestCount > maxGuests) {
                showUnavailableMessage(`Maximum guests allowed is ${maxGuests}.`);
                return false;
            }

            return true;
        }

        function showUnavailableMessage(message) {
            availMsg.style.display = 'none';
            unavailText.textContent = message;
            unavailMsg.style.display = 'block';
        }

        function hideAvailabilityMessages() {
            availMsg.style.display = 'none';
            unavailMsg.style.display = 'none';
        }

        async function checkAvailability() {
            const isValidDate = calculateBooking();

            if (!isValidDate) {
                availMsg.style.display = 'none';
                showValidationModal('Please select valid check-in and check-out dates.');
                return false;
            }

            if (!validateGuestCount()) {
                return false;
            }

            const url = `/booking/@Model.Property_ID/check-availability?checkInDate=${encodeURIComponent(checkin.value)}&checkOutDate=${encodeURIComponent(checkout.value)}`;

            const response = await fetch(url);
            const result = await response.json();

            if (!result.available) {
                availMsg.style.display = 'none';
                showValidationModal(result.message);
                return false;
            }

            availText.textContent = result.message;
            availMsg.style.display = 'flex';
            return true;
        }

        async function openPaymentModal() {
            const available = await checkAvailability();

            if (!available) {
                return;
            }

            const paymentModal = new bootstrap.Modal(document.getElementById('paymentModal'));
            paymentModal.show();
        }

        function computeChange() {
            const amountGiven = parseFloat(document.getElementById('AmountGiven').value) || 0;
            const change = amountGiven - currentTotal;

            document.getElementById('changeAmount').textContent =
                change >= 0 ? formatPeso(change) : 'Insufficient amount';
        }

        function validatePaymentBeforeSubmit() {
            const amountGiven = parseFloat(document.getElementById('AmountGiven').value) || 0;

            if (currentTotal <= 0) {
                showValidationModal('Please select valid check-in and check-out dates first.');
                return;
            }

            if (amountGiven < currentTotal) {
                showValidationModal('Insufficient payment amount. Please enter the exact amount or more.');
                return;
            }

            document.getElementById('bookingForm').submit();
        }

        checkin.addEventListener('change', function () {
            hideAvailabilityMessages();
            calculateBooking();
        });

        checkout.addEventListener('change', function () {
            hideAvailabilityMessages();
            calculateBooking();
        });

        guests.addEventListener('input', function () {
            hideAvailabilityMessages();
        });

        document.getElementById('PaymentMode').addEventListener('change', computeChange);
    </script>
}