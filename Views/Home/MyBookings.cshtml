@model BalayBalayResort.Models.MyBookingsViewModel
@{
    ViewData["Title"] = "My Bookings & Transactions";
    Layout = "_DashboardLayout";
}

<div class="mybookings-wrapper">

    <!-- Search Bar -->
    <form method="get" action="/my-bookings" class="mybookings-search-bar">
        <div class="mybookings-search-input-wrap">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor"
                 viewBox="0 0 16 16" class="mybookings-search-icon">
                <path d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398h-.001c.03.04.062.078.098.115l3.85 3.85a1 1 0 0 0 1.415-1.414l-3.85-3.85a1.007 1.007 0 0 0-.115-.099zm-5.242 1.656a5.5 5.5 0 1 1 0-11 5.5 5.5 0 0 1 0 11z" />
            </svg>
            <input type="text" name="search" class="mybookings-search-input"
                   placeholder="Search Bookings &amp; Transaction"
                   value="@Model.SearchQuery" />
        </div>
        <button type="submit" class="mybookings-filter-btn" title="Search">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                <path d="M1.5 1.5A.5.5 0 0 1 2 1h12a.5.5 0 0 1 .5.5v2a.5.5 0 0 1-.128.334L10 8.692V13.5a.5.5 0 0 1-.342.474l-3 1A.5.5 0 0 1 6 14.5V8.692L1.628 3.834A.5.5 0 0 1 1.5 3.5v-2z" />
            </svg>
        </button>
    </form>

    <!-- Two-column Content -->
    <div class="mybookings-content">

        <!-- Left: My Bookings -->
        <div class="mybookings-col">
            <h2 class="mybookings-col-title">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                    <path d="M3.5 0a.5.5 0 0 1 .5.5V1h8V.5a.5.5 0 0 1 1 0V1h1a2 2 0 0 1 2 2v11a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2V3a2 2 0 0 1 2-2h1V.5a.5.5 0 0 1 .5-.5zM1 4v10a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1V4H1z" />
                </svg>
                My Bookings
            </h2>

            @if (!Model.Bookings.Any())
            {
                <p class="mybookings-empty">No bookings found.</p>
            }
            else
            {
                foreach (var booking in Model.Bookings)
                {
                    <div class="mybooking-card">
                        <div class="mybooking-card-header">
                            <span class="mybooking-card-name">@booking.PropertyName</span>
                            <span class="mybooking-status @booking.Status.ToLower()">@booking.Status</span>
                        </div>
                        <div class="mybooking-card-id">Booking ID: @booking.BookingId</div>
                        <div class="mybooking-card-info">
                            <div>@booking.CheckIn.ToString("yyyy-MM-dd") &ndash; @booking.CheckOut.ToString("yyyy-MM-dd")</div>
                            <div>@booking.Guests guests</div>
                            <div>@booking.PaymentMethod</div>
                        </div>
                        <hr class="mybooking-divider" />
                        <div class="mybooking-total-row">
                            <span class="mybooking-total-label">Total Amount</span>
                            <span class="mybooking-total-amount">&#8369;@booking.TotalAmount.ToString("N0")</span>
                        </div>
                    </div>
                }
            }
        </div>

        <!-- Right: Transaction History -->
        <div class="mybookings-col">
            <h2 class="mybookings-col-title">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                    <path d="M0 4a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2V4zm2-1a1 1 0 0 0-1 1v1h14V4a1 1 0 0 0-1-1H2zm13 4H1v5a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1V7z" />
                    <path d="M2 10a1 1 0 0 1 1-1h1a1 1 0 0 1 1 1v1a1 1 0 0 1-1 1H3a1 1 0 0 1-1-1v-1z" />
                </svg>
                Transaction History
            </h2>

            @if (!Model.Transactions.Any())
            {
                <p class="mybookings-empty">No transactions found.</p>
            }
            else
            {
                foreach (var txn in Model.Transactions)
                {
                    <div class="txn-card">
                        <div class="txn-card-header">
                            <span class="txn-card-id">Transaction @txn.TransactionId</span>
                            <span class="mybooking-status @txn.Status.ToLower()">@txn.Status</span>
                        </div>
                        <div class="txn-card-booking-id">Booking: @txn.BookingId</div>
                        <div class="txn-card-rows">
                            <div class="txn-card-row">
                                <span class="txn-row-label">Payment Method</span>
                                <span class="txn-row-value">@txn.PaymentMethod</span>
                            </div>
                            <div class="txn-card-row">
                                <span class="txn-row-label">Date</span>
                                <span class="txn-row-value">@txn.Date</span>
                            </div>
                            <div class="txn-card-row">
                                <span class="txn-row-label">Reference</span>
                                <span class="txn-row-value">@txn.Reference</span>
                            </div>
                        </div>
                        <hr class="txn-divider" />
                        <div class="mybooking-total-row">
                            <span class="mybooking-total-label">Total</span>
                            <span class="mybooking-total-amount">&#8369;@txn.Total.ToString("N0")</span>
                        </div>
                    </div>
                }
            }
        </div>

    </div>
</div>
