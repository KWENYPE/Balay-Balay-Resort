                    <div class="property-card-footer">
                        <div class="property-card-rating">
                            <span class="star">★</span> 4.3 <span style="color:#aaa;font-weight:400">(97)</span>
                        </div>
                        <div class="property-card-price">₱8,500 <span>/night</span></div>
                    </div>
                </div>
            </div>

        </div>
    </div>

    <!-- Right: Recent Bookings -->
    <div>
        <h2 class="dash-section-title">Recent Bookings</h2>
        <div class="bookings-list">

            <div class="booking-card">
                <div class="booking-card-img">
                    <img src="/images/bg-login.png" alt="Luxurious Beachfront Villa" />
                </div>
                <div class="booking-card-body">
                    <div class="booking-card-name">Luxurious Beachfront Villa</div>
                    <div class="booking-card-dates">2024-01-19 — 2024-01-26</div>
                    <div class="booking-card-price">₱75,000</div>
                    <span class="booking-card-status confirmed">Confirmed</span>
                </div>
            </div>

            <div class="booking-card">
                <div class="booking-card-img">
