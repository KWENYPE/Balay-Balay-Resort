@model BalayBalayResort.ViewModels.LoginViewModel
@{
    ViewData["Title"] = "Login";
    Layout = "_LoginLayout";
}


<!-- DON COMMENTED -->
<div class="login-wrapper">
    <div class="login-card">

        <!-- Logo -->
        <div class="login-logo">
            <img src="/images/UpperDesign.png" alt="Upper Design" class="login-upper-design" />
            <img src="/images/Rentgala-logo.png" alt="RentGala Logo" class="login-logo-img" />
        </div>

        <h2 class="login-title">Welcome Back</h2>
        <p class="login-subtitle">Sign in to continue your journey</p>

        <form asp-action="Login" method="post" novalidate>
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="login-error"></div>

            <div class="form-group-login">
                <label asp-for="Email" class="login-label">Email</label>
                <input asp-for="Email"
                       class="login-input"
                       type="email"
                       placeholder="Enter your email"
                       autocomplete="email" />
                <span asp-validation-for="Email" class="login-field-error"></span>
            </div>

            <div class="form-group-login">
                <label asp-for="Password" class="login-label">Password</label>

                <!-- TODO: DUPLICATE EYE ICON ISSUE
                     - Only ONE eye icon is defined here in the markup
                     - If two icons appear in UI, duplication is likely caused by:
                         1. _LoginLayout.cshtml
                         2. CSS (::after, background-image, or pseudo-elements)
                         3. JavaScript injecting another icon dynamically
                     - Action: Inspect element in browser DevTools to trace duplicate source
                -->
                <div class="password-wrapper">
                    <input asp-for="Password"
                           class="login-input"
                           id="passwordInput"
                           type="password"
                           placeholder="Enter your password"
                           autocomplete="current-password" />

                    <!-- Eye toggle button (expected single instance only) -->
                    <button type="button" class="toggle-pw" onclick="togglePassword()" tabindex="-1">
                        <svg id="eyeIcon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 16 16">
                            <path d="M16 8s-3-5.5-8-5.5S0 8 0 8s3 5.5 8 5.5S16 8 16 8zM1.173 8a13.133 13.133 0 0 1 1.66-2.043C4.12 4.668 5.88 3.5 8 3.5c2.12 0 3.879 1.168 5.168 2.457A13.133 13.133 0 0 1 14.828 8c-.058.087-.122.183-.195.288-.335.48-.83 1.12-1.465 1.755C11.879 11.332 10.119 12.5 8 12.5c-2.12 0-3.879-1.168-5.168-2.457A13.134 13.134 0 0 1 1.172 8z" />
                            <path d="M8 5.5a2.5 2.5 0 1 0 0 5 2.5 2.5 0 0 0 0-5zM4.5 8a3.5 3.5 0 1 1 7 0 3.5 3.5 0 0 1-7 0z" />
                        </svg>
                    </button>
                </div>

                <span asp-validation-for="Password" class="login-field-error"></span>
            </div>

            <div class="login-options">
                <label class="remember-label">
                    <input asp-for="RememberMe" type="checkbox" class="remember-check" />
                    Remember me
                </label>

                <!--TODO: FORGOT PASSWORD NOT WORKING
                     - Current link uses href="#" which does nothing
                     - No navigation or function is triggered
                     - Needs either:
                         1. Backend route (Account/ForgotPassword)
                         2. Temporary UI behavior (modal or alert)
                     - Status: Not yet implemented / non-functional
                -->
                <a href="#" class="forgot-link">Forgot Password?</a>
            </div>

            <button type="submit" class="btn-signin">Sign In</button>
        </form>

        <p class="login-register">
            Don't have an account?
            <a asp-controller="Account" asp-action="Register" class="register-link">Register</a>
        </p>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        function togglePassword() {

            const input = document.getElementById('passwordInput');
            input.type = input.type === 'password' ? 'text' : 'password';
        }
    </script>
}