@model BalayBalayResort.ViewModels.RegisterViewModel
@{
    ViewData["Title"] = "Register";
    Layout = "_LoginLayout";
}
<!-- DON COMMENTED -->
<div class="login-wrapper">
    <div class="login-card register-card">

        <h2 class="login-title">Create Account</h2>
        <p class="login-subtitle">Join us to start your journey</p>

        <form asp-action="Register" method="post" novalidate enctype="multipart/form-data">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="login-error"></div>

            <!-- Profile Picture Upload -->
            <!-- TODO: ISSUE - UPLOAD IMAGE OVERLAPS TEXT
                 - Uploaded image covers or overlaps the "Upload Profile Picture" text
                 - Likely caused by CSS positioning (z-index, absolute/relative, or sizing issue)
                 - Check styling of:
                     .profile-avatar
                     .profile-upload-label
                     img#avatarPreview
                 - Fix should ensure text remains visible or properly spaced
            -->
            <div class="profile-upload-wrapper">
                <div class="profile-avatar" id="avatarCircle">
                    <svg xmlns="http://www.w3.org/2000/svg" width="52" height="52" fill="currentColor" viewBox="0 0 16 16">
                        <path d="M11 6a3 3 0 1 1-6 0 3 3 0 0 1 6 0z" />
                        <path fill-rule="evenodd" d="M0 8a8 8 0 1 1 16 0A8 8 0 0 1 0 8zm8-7a7 7 0 0 0-5.468 11.37C3.242 11.226 4.805 10 8 10s4.757 1.225 5.468 2.37A7 7 0 0 0 8 1z" />
                    </svg>
                    <img id="avatarPreview" src="" alt="Preview" style="display:none;" />
                </div>
                <button type="button" class="profile-upload-btn" onclick="document.getElementById('profilePicInput').click()">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
                        <path d="M.5 9.9a.5.5 0 0 1 .5.5v2.5a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1v-2.5a.5.5 0 0 1 1 0v2.5a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2v-2.5a.5.5 0 0 1 .5-.5z" />
                        <path d="M7.646 1.146a.5.5 0 0 1 .708 0l3 3a.5.5 0 0 1-.708.708L8.5 2.707V11.5a.5.5 0 0 1-1 0V2.707L5.354 4.854a.5.5 0 1 1-.708-.708l3-3z" />
                    </svg>
                </button>
                <input type="file" id="profilePicInput" name="ProfilePicture" accept="image/*" style="display:none;" />
                <p class="profile-upload-label">Upload Profile Picture</p>
            </div>

            <div class="form-group-login">
                <label asp-for="FullName" class="login-label">Full Name</label>
                <input asp-for="FullName"
                       class="login-input"
                       type="text"
                       placeholder="Enter your full name"
                       autocomplete="name" />
                <span asp-validation-for="FullName" class="login-field-error"></span>
            </div>

            <div class="form-group-login">
                <label asp-for="Email" class="login-label">Email</label>
                <input asp-for="Email"
                       class="login-input"
                       type="email"
                       placeholder="Enter your email"
                       autocomplete="email" />
                <span asp-validation-for="Email" class="login-field-error"></span>
            </div>

            <div class="form-group-login">
                <label asp-for="PhoneNumber" class="login-label">Phone No.</label>

                <!-- TODO: VALIDATION - SHOULD ONLY ACCEPT PHONE NUMBER
                     - Ensure input accepts only numeric phone number format
                     - Consider adding validation (regex or model validation)
                     - Prevent letters or invalid characters
                -->
                <input asp-for="PhoneNumber"
                       class="login-input"
                       type="tel"
                       placeholder="Enter your phone number"
                       autocomplete="tel" />
                <span asp-validation-for="PhoneNumber" class="login-field-error"></span>
            </div>

            <div class="form-group-login">
                <label asp-for="Password" class="login-label">Password</label>

                <!-- TODO: UI CHECK - PASSWORD FIELD HAS EYE ICON
                     - This field has one toggle (eye icon)
                     - Confirm behavior is correct and not duplicated
                -->
                <div class="password-wrapper">
                    <input asp-for="Password"
                           class="login-input"
                           id="passwordInput"
                           type="password"
                           placeholder="Enter your password"
                           autocomplete="new-password" />
                    <button type="button" class="toggle-pw" onclick="togglePassword('passwordInput')" tabindex="-1">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 16 16">
                            <path d="M16 8s-3-5.5-8-5.5S0 8 0 8s3 5.5 8 5.5S16 8 16 8zM1.173 8a13.133 13.133 0 0 1 1.66-2.043C4.12 4.668 5.88 3.5 8 3.5c2.12 0 3.879 1.168 5.168 2.457A13.133 13.133 0 0 1 14.828 8c-.058.087-.122.183-.195.288-.335.48-.83 1.12-1.465 1.755C11.879 11.332 10.119 12.5 8 12.5c-2.12 0-3.879-1.168-5.168-2.457A13.134 13.134 0 0 1 1.172 8z" />
                            <path d="M8 5.5a2.5 2.5 0 1 0 0 5 2.5 2.5 0 0 0 0-5zM4.5 8a3.5 3.5 0 1 1 7 0 3.5 3.5 0 0 1-7 0z" />
                        </svg>
                    </button>
                </div>
                <span asp-validation-for="Password" class="login-field-error"></span>
            </div>

            <div class="form-group-login">
                <label asp-for="ConfirmPassword" class="login-label">Confirm Password</label>

                <!-- TODO: UI CHECK - CONFIRM PASSWORD ALSO HAS EYE ICON
                     - Both Password and Confirm Password have toggle icons ("two eyes")
                     - This is expected, but ensure:
                         1. They work independently
                         2. No duplicate icons appear per field
                -->
                <div class="password-wrapper">
                    <input asp-for="ConfirmPassword"
                           class="login-input"
                           id="confirmPasswordInput"
                           type="password"
                           placeholder="Confirm your password"
                           autocomplete="new-password" />
                    <button type="button" class="toggle-pw" onclick="togglePassword('confirmPasswordInput')" tabindex="-1">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 16 16">
                            <path d="M16 8s-3-5.5-8-5.5S0 8 0 8s3 5.5 8 5.5S16 8 16 8zM1.173 8a13.133 13.133 0 0 1 1.66-2.043C4.12 4.668 5.88 3.5 8 3.5c2.12 0 3.879 1.168 5.168 2.457A13.133 13.133 0 0 1 14.828 8c-.058.087-.122.183-.195.288-.335.48-.83 1.12-1.465 1.755C11.879 11.332 10.119 12.5 8 12.5c-2.12 0-3.879-1.168-5.168-2.457A13.134 13.134 0 0 1 1.172 8z" />
                            <path d="M8 5.5a2.5 2.5 0 1 0 0 5 2.5 2.5 0 0 0 0-5zM4.5 8a3.5 3.5 0 1 1 7 0 3.5 3.5 0 0 1-7 0z" />
                        </svg>
                    </button>
                </div>
                <span asp-validation-for="ConfirmPassword" class="login-field-error"></span>
            </div>

            <button type="submit" class="btn-signin">Create Account</button>
        </form>

        <p class="login-register">
            Have an account?
            <a asp-controller="Account" asp-action="Login" class="register-link">Sign In</a>
        </p>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        function togglePassword(inputId) {
            const input = document.getElementById(inputId);
            input.type = input.type === 'password' ? 'text' : 'password';
        }

        document.getElementById('profilePicInput').addEventListener('change', function () {

            // TODO: CHECK IMAGE PREVIEW BEHAVIOR
            // - Ensure uploaded image does not overlap UI text
            // - Confirm preview replaces icon properly without layout issues

            const file = this.files[0];
            if (file) {
                const reader = new FileReader();
                reader.onload = function (e) {
                    const preview = document.getElementById('avatarPreview');
                    const circle = document.getElementById('avatarCircle');
                    preview.src = e.target.result;
                    preview.style.display = 'block';
                    circle.querySelector('svg').style.display = 'none';
                };
                reader.readAsDataURL(file);
            }
        });
    </script>
}