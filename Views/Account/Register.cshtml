@model Balay_Balay_Resort.ViewModels.RegisterViewModel
@{
    ViewData["Title"] = "Register";
    Layout = "_LoginLayout";
}
<!-- DON COMMENTED -->
<div class="login-wrapper">
    <div class="login-card register-card">

        <h2 class="login-title">Create Account</h2>
        <p class="login-subtitle">Join us to start your journey</p>

        <form asp-action="Register" method="post" novalidate enctype="multipart/form-data">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="login-error"></div>

            <!-- Profile Picture Upload -->
            <div class="profile-upload-wrapper">
                <div class="profile-avatar" id="avatarCircle"
                     style="position:relative;width:90px;height:90px;border-radius:50%;background:rgba(55,28,8,0.80);border:2px solid rgba(200,164,110,0.55);display:flex;align-items:center;justify-content:center;color:rgba(200,164,110,0.85);overflow:hidden;cursor:pointer;flex-shrink:0;"
                     onclick="document.getElementById('profilePicInput').click()">
                    <svg id="avatarSvg" xmlns="http://www.w3.org/2000/svg" width="52" height="52" fill="currentColor" viewBox="0 0 16 16">
                        <path d="M11 6a3 3 0 1 1-6 0 3 3 0 0 1 6 0z" />
                        <path fill-rule="evenodd" d="M0 8a8 8 0 1 1 16 0A8 8 0 0 1 0 8zm8-7a7 7 0 0 0-5.468 11.37C3.242 11.226 4.805 10 8 10s4.757 1.225 5.468 2.37A7 7 0 0 0 8 1z" />
                    </svg>
                    <img id="avatarPreview" src="" alt="Preview"
                         style="display:none;position:absolute;top:0;left:0;width:100%;height:100%;object-fit:cover;border-radius:50%;" />
                </div>
                <div style="display:flex;flex-direction:column;align-items:center;gap:6px;margin-top:8px;">
                    <p class="profile-upload-label" style="margin:0;font-size:0.82rem;color:#7a5530;font-weight:500;">Upload Profile Picture</p>
                    <button type="button" class="profile-upload-btn" onclick="document.getElementById('profilePicInput').click()">
                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
                            <path d="M.5 9.9a.5.5 0 0 1 .5.5v2.5a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1v-2.5a.5.5 0 0 1 1 0v2.5a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2v-2.5a.5.5 0 0 1 .5-.5z" />
                            <path d="M7.646 1.146a.5.5 0 0 1 .708 0l3 3a.5.5 0 0 1-.708.708L8.5 2.707V11.5a.5.5 0 0 1-1 0V2.707L5.354 4.854a.5.5 0 1 1-.708-.708l3-3z" />
                        </svg>
                        Choose Photo
                    </button>
                </div>
                <input asp-for="ProfilePicture" type="file" id="profilePicInput" accept="image/*" style="display:none;" />
            </div>

            <div class="form-group-login">
                <label asp-for="FullName" class="login-label">Full Name</label>
                <input asp-for="FullName"
                       class="login-input"
                       type="text"
                       placeholder="Enter your full name"
                       autocomplete="name" />
                <span asp-validation-for="FullName" class="login-field-error"></span>
            </div>

            <div class="form-group-login">
                <label asp-for="Email" class="login-label">Email</label>
                <input asp-for="Email"
                       class="login-input"
                       type="email"
                       placeholder="Enter your email"
                       autocomplete="email" />
                <span asp-validation-for="Email" class="login-field-error"></span>
            </div>

            <div class="form-group-login">
                <label asp-for="PhoneNumber" class="login-label">Phone No.</label>

                <!-- TODO: VALIDATION - SHOULD ONLY ACCEPT PHONE NUMBER
                     - Ensure input accepts only numeric phone number format
                     - Consider adding validation (regex or model validation)
                     - Prevent letters or invalid characters
                -->
                <input asp-for="PhoneNumber"
                       class="login-input"
                       type="tel"
                       placeholder="Enter your phone number"
                       autocomplete="tel" />
                <span asp-validation-for="PhoneNumber" class="login-field-error"></span>
            </div>

            <div class="form-group-login">
                <label asp-for="Password" class="login-label">Password</label>
                <div class="password-wrapper">
                    <input asp-for="Password"
                           class="login-input"
                           id="passwordInput"
                           type="password"
                           placeholder="Enter your password"
                           autocomplete="new-password" />
                    <button type="button" class="toggle-pw" id="eyeBtn1" onclick="togglePassword('passwordInput','eyeBtn1')" tabindex="-1">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 16 16">
                            <path d="M16 8s-3-5.5-8-5.5S0 8 0 8s3 5.5 8 5.5S16 8 16 8zM1.173 8a13.133 13.133 0 0 1 1.66-2.043C4.12 4.668 5.88 3.5 8 3.5c2.12 0 3.879 1.168 5.168 2.457A13.133 13.133 0 0 1 14.828 8c-.058.087-.122.183-.195.288-.335.48-.83 1.12-1.465 1.755C11.879 11.332 10.119 12.5 8 12.5c-2.12 0-3.879-1.168-5.168-2.457A13.134 13.134 0 0 1 1.172 8z"/>
                            <path d="M8 5.5a2.5 2.5 0 1 0 0 5 2.5 2.5 0 0 0 0-5zM4.5 8a3.5 3.5 0 1 1 7 0 3.5 3.5 0 0 1-7 0z"/>
                        </svg>
                    </button>
                </div>
                <span asp-validation-for="Password" class="login-field-error"></span>
            </div>

            <div class="form-group-login">
                <label asp-for="ConfirmPassword" class="login-label">Confirm Password</label>
                <div class="password-wrapper">
                    <input asp-for="ConfirmPassword"
                           class="login-input"
                           id="confirmPasswordInput"
                           type="password"
                           placeholder="Confirm your password"
                           autocomplete="new-password" />
                    <button type="button" class="toggle-pw" id="eyeBtn2" onclick="togglePassword('confirmPasswordInput','eyeBtn2')" tabindex="-1">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 16 16">
                            <path d="M16 8s-3-5.5-8-5.5S0 8 0 8s3 5.5 8 5.5S16 8 16 8zM1.173 8a13.133 13.133 0 0 1 1.66-2.043C4.12 4.668 5.88 3.5 8 3.5c2.12 0 3.879 1.168 5.168 2.457A13.133 13.133 0 0 1 14.828 8c-.058.087-.122.183-.195.288-.335.48-.83 1.12-1.465 1.755C11.879 11.332 10.119 12.5 8 12.5c-2.12 0-3.879-1.168-5.168-2.457A13.134 13.134 0 0 1 1.172 8z"/>
                            <path d="M8 5.5a2.5 2.5 0 1 0 0 5 2.5 2.5 0 0 0 0-5zM4.5 8a3.5 3.5 0 1 1 7 0 3.5 3.5 0 0 1-7 0z"/>
                        </svg>
                    </button>
                </div>
                <span asp-validation-for="ConfirmPassword" class="login-field-error"></span>
            </div>

            <button type="submit" class="btn-signin">Create Account</button>
        </form>

        <p class="login-register">
            Have an account?
            <a asp-controller="Account" asp-action="Login" class="register-link">Sign In</a>
        </p>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        const eyeSvg = `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 16 16">
            <path d="M16 8s-3-5.5-8-5.5S0 8 0 8s3 5.5 8 5.5S16 8 16 8zM1.173 8a13.133 13.133 0 0 1 1.66-2.043C4.12 4.668 5.88 3.5 8 3.5c2.12 0 3.879 1.168 5.168 2.457A13.133 13.133 0 0 1 14.828 8c-.058.087-.122.183-.195.288-.335.48-.83 1.12-1.465 1.755C11.879 11.332 10.119 12.5 8 12.5c-2.12 0-3.879-1.168-5.168-2.457A13.134 13.134 0 0 1 1.172 8z"/>
            <path d="M8 5.5a2.5 2.5 0 1 0 0 5 2.5 2.5 0 0 0 0-5zM4.5 8a3.5 3.5 0 1 1 7 0 3.5 3.5 0 0 1-7 0z"/>
        </svg>`;
        const eyeSlashSvg = `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 16 16">
            <path d="M13.359 11.238C15.06 9.72 16 8 16 8s-3-5.5-8-5.5a7.028 7.028 0 0 0-2.79.588l.77.771A5.944 5.944 0 0 1 8 3.5c2.12 0 3.879 1.168 5.168 2.457A13.134 13.134 0 0 1 14.828 8c-.058.087-.122.183-.195.288-.335.48-.83 1.12-1.465 1.755-.165.165-.337.328-.517.486l.708.709z"/>
            <path d="M11.297 9.176a3.5 3.5 0 0 0-4.474-4.474l.823.823a2.5 2.5 0 0 1 2.829 2.829l.822.822zm-2.943 1.299.822.822a3.5 3.5 0 0 1-4.474-4.474l.823.823a2.5 2.5 0 0 0 2.829 2.829z"/>
            <path d="M3.35 5.47c-.18.16-.353.322-.518.487A13.134 13.134 0 0 0 1.172 8l.195.288c.335.48.83 1.12 1.465 1.755C4.121 11.332 5.881 12.5 8 12.5c.716 0 1.39-.133 2.02-.36l.77.772A7.029 7.029 0 0 1 8 13.5C3 13.5 0 8 0 8s.939-1.721 2.641-3.238l.708.709z"/>
            <path fill-rule="evenodd" d="M13.646 14.354l-12-12 .708-.708 12 12-.708.708z"/>
        </svg>`;

        function togglePassword(inputId, btnId) {
            const input = document.getElementById(inputId);
            const btn   = document.getElementById(btnId);
            const show  = input.type === 'password';
            input.type  = show ? 'text' : 'password';
            btn.innerHTML = show ? eyeSlashSvg : eyeSvg;
        }

        document.getElementById('profilePicInput').addEventListener('change', function () {
            const file = this.files[0];
            if (!file) return;
            const reader = new FileReader();
            reader.onload = function (e) {
                const preview = document.getElementById('avatarPreview');
                const svg     = document.getElementById('avatarSvg');
                preview.src = e.target.result;
                preview.style.display = 'block';
                svg.style.display = 'none';
            };
            reader.readAsDataURL(file);
        });
    </script>
}