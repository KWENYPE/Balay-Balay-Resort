@model Balay_Balay_Resort.ViewModels.AdminTransactionsViewModel
@{
    ViewData["Title"] = "Transactions";
    Layout = "_AdminLayout";
}

<div class="admin-txn-page-header">
    <h1 class="admin-page-title" style="margin-bottom:0">Transactions</h1>
</div>

<div class="admin-txn-stats">
    <div class="admin-txn-stat-card">
        <div class="admin-txn-stat-label">Total Transactions</div>
        <div class="admin-txn-stat-value">@Model.TotalTransactions</div>
    </div>

    <div class="admin-txn-stat-card">
        <div class="admin-txn-stat-label">Total Revenue</div>
        <div class="admin-txn-stat-value">&#8369;@Model.TotalRevenue.ToString("N0")</div>
    </div>

    <div class="admin-txn-stat-card">
        <div class="admin-txn-stat-label">Completed</div>
        <div class="admin-txn-stat-value">@Model.Completed</div>
    </div>
</div>

<form method="get" action="/admin/transactions" class="admin-txn-search-bar">
    <div class="admin-props-search-wrap">
        <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" fill="currentColor"
             viewBox="0 0 16 16" class="admin-props-search-icon">
            <path d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398h-.001c.03.04.062.078.098.115l3.85 3.85a1 1 0 0 0 1.415-1.414l-3.85-3.85a1.007 1.007 0 0 0-.115-.099zm-5.242 1.656a5.5 5.5 0 1 1 0-11 5.5 5.5 0 0 1 0 11z" />
        </svg>
        <input type="text" name="search" class="admin-props-search-input"
               placeholder="Search Transactions" value="@Model.SearchQuery" />
    </div>
    <button type="submit" class="admin-props-filter-btn" title="Search">
        <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" fill="currentColor" viewBox="0 0 16 16">
            <path d="M1.5 1.5A.5.5 0 0 1 2 1h12a.5.5 0 0 1 .5.5v2a.5.5 0 0 1-.128.334L10 8.692V13.5a.5.5 0 0 1-.342.474l-3 1A.5.5 0 0 1 6 14.5V8.692L1.628 3.834A.5.5 0 0 1 1.5 3.5v-2z" />
        </svg>
    </button>
</form>

<div class="admin-txn-table-wrap">
    <table class="admin-txn-table">
        <thead>
            <tr>
                <th>Transaction ID</th>
                <th>Booking</th>
                <th>Amount</th>
                <th>Method</th>
                <th>Date</th>
                <th>Reference</th>
                <th>Status</th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.Transactions.Any())
            {
                <tr>
                    <td colspan="7" style="text-align:center; padding:24px; color:#9ca3af;">No transactions found.</td>
                </tr>
            }
            else
            {
                @foreach (var t in Model.Transactions)
                {
                    var statusClass = (t.Status ?? "pending").ToLower();
                    <tr>
                        <td class="admin-txn-id-cell">@t.TransactionId</td>
                        <td class="admin-txn-booking-cell">
                            <div class="admin-txn-booking-id">@t.BookingId</div>
                            <div class="admin-txn-prop-name">@t.PropertyName</div>
                        </td>
                        <td>&#8369;@t.Amount.ToString("N0")</td>
                        <td>@t.Method</td>
                        <td>@t.Date</td>
                        <td class="admin-txn-ref-cell">@t.Reference</td>
                        <td><span class="admin-txn-status @statusClass">@t.Status</span></td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>
