@model Balay_Balay_Resort.ViewModels.AdminTransactionsViewModel
@{
    ViewData["Title"] = "Transactions";
    Layout = "_AdminLayout";
}

<div class="admin-txn-page-header">
    <h1 class="admin-page-title" style="margin-bottom:0">Transactions</h1>
</div>

<div class="admin-txn-stats">
    <div class="admin-txn-stat-card">
        <div class="admin-txn-stat-label">Total Transactions</div>
        <div class="admin-txn-stat-value">@Model.TotalTransactions</div>
    </div>

    <div class="admin-txn-stat-card">
        <div class="admin-txn-stat-label">Total Revenue</div>
        <div class="admin-txn-stat-value">&#8369;@Model.TotalRevenue.ToString("N0")</div>
    </div>

    <div class="admin-txn-stat-card">
        <div class="admin-txn-stat-label">Completed</div>
        <div class="admin-txn-stat-value">@Model.Completed</div>
    </div>
</div>

<form method="get" action="/admin/transactions" class="admin-txn-search-bar">
    <div class="admin-props-search-wrap">
        <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" fill="currentColor"
             viewBox="0 0 16 16" class="admin-props-search-icon">
            <path d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398h-.001c.03.04.062.078.098.115l3.85 3.85a1 1 0 0 0 1.415-1.414l-3.85-3.85a1.007 1.007 0 0 0-.115-.099zm-5.242 1.656a5.5 5.5 0 1 1 0-11 5.5 5.5 0 0 1 0 11z" />
        </svg>
        <input type="text" name="search" class="admin-props-search-input"
               placeholder="Search Transactions" value="@Model.SearchQuery" />
    </div>
    <button type="submit" class="admin-props-filter-btn" title="Search">
        <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" fill="currentColor" viewBox="0 0 16 16">
            <path d="M1.5 1.5A.5.5 0 0 1 2 1h12a.5.5 0 0 1 .5.5v2a.5.5 0 0 1-.128.334L10 8.692V13.5a.5.5 0 0 1-.342.474l-3 1A.5.5 0 0 1 6 14.5V8.692L1.628 3.834A.5.5 0 0 1 1.5 3.5v-2z" />
        </svg>
    </button>
</form>

<div class="admin-txn-table-wrap">
    <table class="admin-txn-table">
        <thead>
            <tr>
                <th>Transaction ID</th>
                <th>Booking</th>
                <th>Amount</th>
                <th>Method</th>
                <th>Date</th>
                <th>Reference</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.Transactions.Any())
            {
                <tr>
                    <td colspan="8" style="text-align:center; padding:24px; color:#9ca3af;">No transactions found.</td>
                </tr>
            }
            else
            {
                @foreach (var t in Model.Transactions)
                {
                    var statusClass = (t.Status ?? "pending").ToLower();
                    var transactionNumericId = int.Parse(t.TransactionId.Replace("TXN", ""));
                    <tr>
                        <td class="admin-txn-id-cell">@t.TransactionId</td>

                        <td class="admin-txn-booking-cell">
                            <div class="admin-txn-booking-id">@t.BookingId</div>
                            <div class="admin-txn-prop-name">@t.PropertyName</div>
                        </td>

                        <td>&#8369;@t.Amount.ToString("N0")</td>
                        <td>@t.Method</td>
                        <td>@t.Date</td>
                        <td class="admin-txn-ref-cell">@t.Reference</td>
                        <td><span class="admin-txn-status @statusClass">@t.Status</span></td>

                        <td>
                            <div class="admin-txn-actions">
                                <button type="button"
                                        class="admin-txn-edit-btn"
                                        data-bs-toggle="modal"
                                        data-bs-target="#editTransactionModal-@transactionNumericId"
                                        title="Edit Transaction">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                                        <path d="M12.146.854a.5.5 0 0 1 .708 0l2.292 2.292a.5.5 0 0 1 0 .708l-9.5 9.5a.5.5 0 0 1-.168.11l-4 1.5a.5.5 0 0 1-.642-.642l1.5-4a.5.5 0 0 1 .11-.168l9.5-9.5zM11.207 2.5 13.5 4.793 14.086 4 12 1.914 11.207 2.5zM10.5 3.207 3 10.707V12h1.293l7.5-7.5-1.293-1.293z" />
                                    </svg>
                                </button>
                            </div>

                            <!-- EDIT TRANSACTION MODAL -->
                            <div class="modal fade" id="editTransactionModal-@transactionNumericId" tabindex="-1" aria-hidden="true">
                                <div class="modal-dialog modal-dialog-centered">
                                    <div class="modal-content" style="border-radius:14px; border:none; overflow:hidden;">
                                        <form method="post" action="/admin/transactions/edit/@transactionNumericId">
                                            @Html.AntiForgeryToken()

                                            <div class="modal-header">
                                                <h5 class="modal-title">Edit Transaction</h5>
                                                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                            </div>

                                            <div class="modal-body">
                                                <div class="admin-edit-field">
                                                    <label>Amount</label>
                                                    <input type="number"
                                                           name="Amount"
                                                           class="admin-edit-input"
                                                           min="0"
                                                           step="0.01"
                                                           value="@t.Amount"
                                                           required />
                                                </div>

                                                <div class="admin-edit-field">
                                                    <label>Payment Method</label>
                                                    <select name="PaymentMode" class="admin-edit-input" required>
                                                        <option value="Cash" selected="@(t.Method == "Cash")">Cash</option>
                                                        <option value="GCash" selected="@(t.Method == "GCash")">GCash</option>
                                                        <option value="Bank Transfer" selected="@(t.Method == "Bank Transfer")">Bank Transfer</option>
                                                    </select>
                                                </div>

                                                <div class="admin-edit-field">
                                                    <label>Date</label>
                                                    <input type="date"
                                                           name="Date"
                                                           class="admin-edit-input"
                                                           value="@t.Date"
                                                           required />
                                                </div>

                                                <div class="admin-edit-field">
                                                    <label>Reference Number</label>
                                                    <input type="text"
                                                           name="ReferenceNum"
                                                           class="admin-edit-input"
                                                           value="@t.Reference" />
                                                </div>

                                                <div class="admin-edit-field">
                                                    <label>Status</label>
                                                    <select name="Status" class="admin-edit-input" required>
                                                        <option value="Pending" selected="@(t.Status == "Pending")">Pending</option>
                                                        <option value="Completed" selected="@(t.Status == "Completed")">Completed</option>
                                                        <option value="Cancelled" selected="@(t.Status == "Cancelled")">Cancelled</option>
                                                    </select>
                                                </div>
                                            </div>

                                            <div class="modal-footer">
                                                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                                                    Cancel
                                                </button>

                                                <button type="submit" class="btn btn-primary" style="background:#111827; border:none;">
                                                    Save Changes
                                                </button>
                                            </div>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>
