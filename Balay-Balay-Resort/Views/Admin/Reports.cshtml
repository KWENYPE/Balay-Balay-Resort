@model Balay_Balay_Resort.ViewModels.AdminReportsViewModel
@{
    ViewData["Title"] = "Reports";
    Layout = "_AdminLayout";
}

<div class="rpt-header">
    <h1 class="admin-page-title" style="margin-bottom:0">Reports</h1>
</div>

<div class="rpt-stats-grid">
    <div class="rpt-stat-card" style="background:#2563eb;">
        <div class="rpt-stat-top">Total Revenue</div>
        <div class="rpt-stat-value">&#8369;@Model.TotalRevenue.ToString("N0")</div>
        <div class="rpt-stat-sub">Completed transactions</div>
    </div>

    <div class="rpt-stat-card" style="background:#16a34a;">
        <div class="rpt-stat-top">Total Bookings</div>
        <div class="rpt-stat-value">@Model.TotalBookings</div>
        <div class="rpt-stat-sub">All booking records</div>
    </div>

    <div class="rpt-stat-card" style="background:#9333ea;">
        <div class="rpt-stat-top">Average Booking Value</div>
        <div class="rpt-stat-value">&#8369;@Model.AvgBookingValue.ToString("N0")</div>
        <div class="rpt-stat-sub">Average total amount</div>
    </div>

    <div class="rpt-stat-card" style="background:#f59e0b;">
        <div class="rpt-stat-top">Customer Satisfaction</div>
        <div class="rpt-stat-value">@Model.CustomerSatisfaction.ToString("0.0")</div>
        <div class="rpt-stat-sub">Average review rating</div>
    </div>
</div>

<div class="rpt-mid-grid">
    <div class="rpt-card">
        <h2 class="rpt-card-title">Top Properties</h2>
        <div class="rpt-prop-list">
            @if (!Model.TopProperties.Any())
            {
                <div style="color:#9ca3af;">No property booking data yet.</div>
            }
            else
            {
                @foreach (var p in Model.TopProperties)
                {
                    <div class="rpt-prop-row">
                        <div class="rpt-prop-rank">@p.Rank</div>
                        <div class="rpt-prop-img">
                            <img src="@p.ImageUrl" alt="@p.Name" />
                        </div>
                        <div class="rpt-prop-info">
                            <div class="rpt-prop-name">@p.Name</div>
                            <div class="rpt-prop-location">@p.Location</div>
                        </div>
                        <div class="rpt-prop-stats">
                            <div class="rpt-prop-revenue">&#8369;@p.Revenue.ToString("N0")</div>
                            <div class="rpt-prop-bookings">@p.Bookings bookings</div>
                        </div>
                    </div>
                }
            }
        </div>
    </div>

    <div class="rpt-card">
        <h2 class="rpt-card-title">Payment Methods</h2>
        <div class="rpt-pay-list">
            @if (!Model.PaymentMethods.Any())
            {
                <div style="color:#9ca3af;">No completed payment data yet.</div>
            }
            else
            {
                @foreach (var p in Model.PaymentMethods)
                {
                    <div class="rpt-pay-row">
                        <div class="rpt-pay-icon" style="background:@p.Color;">@p.Code</div>
                        <div class="rpt-pay-info">
                            <div class="rpt-pay-name">@p.Name</div>
                            <div class="rpt-pay-txn">@p.Transactions transactions</div>
                        </div>
                        <div class="rpt-pay-right">
                            <div class="rpt-pay-amount">&#8369;@p.Amount.ToString("N0")</div>
                            <div class="rpt-pay-pct">@p.Percentage%</div>
                        </div>
                    </div>
                }
            }
        </div>
    </div>
</div>

<div class="rpt-mid-grid">
    <div class="rpt-card">
        <h2 class="rpt-card-title">Booking Status</h2>
        <div class="rpt-status-list">
            <div class="rpt-status-row rpt-status-confirmed">
                <span>Confirmed</span>
                <span class="rpt-status-count">@Model.ConfirmedBookings</span>
            </div>
            <div class="rpt-status-row rpt-status-pending">
                <span>Pending</span>
                <span class="rpt-status-count">@Model.PendingBookings</span>
            </div>
            <div class="rpt-status-row rpt-status-cancelled">
                <span>Cancelled</span>
                <span class="rpt-status-count">@Model.CancelledBookings</span>
            </div>
        </div>
    </div>

    <div class="rpt-card">
        <h2 class="rpt-card-title">Occupancy Rate</h2>
        <div class="rpt-trends-list">
            <div class="rpt-trend-item">
                <div class="rpt-trend-header">
                    <span class="rpt-trend-label">Confirmed bookings out of total bookings</span>
                    <span class="rpt-trend-value">@Model.OccupancyRate%</span>
                </div>
                <div class="rpt-trend-bar-bg">
                    <div class="rpt-trend-bar" style="width:@Model.OccupancyRate%; background:#2563eb;"></div>
                </div>
            </div>
        </div>
    </div>
</div>
