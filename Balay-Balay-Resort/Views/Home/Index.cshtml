@using Balay_Balay_Resort.Models

@{
    ViewData["Title"] = "Dashboard";
    Layout = "_DashboardLayout";

    var recommendedProperties = ViewBag.RecommendedProperties as List<Property>;
    var recentBookings = ViewBag.RecentBookings as List<Booking>;
}

<!-- Hero Banner -->
<div class="dash-hero">
    <div class="dash-hero-bg"></div>
    <img src="/images/Dashboard-bg.png" alt="" class="dash-hero-upper" />

    <div class="dash-hero-content">
        <div class="dash-hero-left">
            <a href="/edit-profile" class="dash-hero-avatar" title="Edit Profile">
                @if (!string.IsNullOrWhiteSpace(ViewBag.ProfileImagePath as string))
                {
                    <img src="@ViewBag.ProfileImagePath" alt="Profile Picture" class="dash-profile-img" />
                }
                else
                {
                    <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" fill="currentColor" viewBox="0 0 16 16">
                        <path d="M11 6a3 3 0 1 1-6 0 3 3 0 0 1 6 0z" />
                        <path fill-rule="evenodd" d="M0 8a8 8 0 1 1 16 0A8 8 0 0 1 0 8zm8-7a7 7 0 0 0-5.468 11.37C3.242 11.226 4.805 10 8 10s4.757 1.225 5.468 2.37A7 7 0 0 0 8 1z" />
                    </svg>
                }
            </a>

            <div class="dash-hero-info">
                <h1 class="dash-hero-title">Welcome Back!</h1>
                <div class="dash-hero-name">@ViewBag.FullName</div>
                <div class="dash-hero-badge">@ViewBag.UserType</div>
            </div>
        </div>

        <a href="/edit-profile" class="dash-hero-edit-btn">
            Edit Profile
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
                <path fill-rule="evenodd" d="M4 8a.5.5 0 0 1 .5-.5h5.793L8.146 5.354a.5.5 0 1 1 .708-.708l3 3a.5.5 0 0 1 0 .708l-3 3a.5.5 0 0 1-.708-.708L10.293 8.5H4.5A.5.5 0 0 1 4 8z" />
            </svg>
        </a>
    </div>
</div>

<!-- Main Content -->
<div class="dash-content">

    <!-- Left: Recommended Properties -->
    <div>
        <h2 class="dash-section-title">Recommended Vacation Rental for You</h2>

        <div class="property-grid">
            @if (recommendedProperties != null && recommendedProperties.Any())
            {
                foreach (var property in recommendedProperties)
                {
                    var averageRating = property.Feedbacks != null && property.Feedbacks.Any()
                        ? property.Feedbacks.Average(f => f.ReviewRate)
                        : 0;

                    var reviewCount = property.Feedbacks?.Count ?? 0;

                    <a href="/property/@property.Property_ID" class="property-card" style="text-decoration:none; color:inherit;">
                        <div class="property-card-img">
                            <img src="@(string.IsNullOrWhiteSpace(property.PropertyImagePath) ? "/images/bg-login.png" : property.PropertyImagePath)"
                                 alt="@property.Property_Name" />
                        </div>

                        <div class="property-card-body">
                            <div class="property-card-location">
                                <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" fill="currentColor" viewBox="0 0 16 16">
                                    <path d="M8 16s6-5.686 6-10A6 6 0 0 0 2 6c0 4.314 6 10 6 10zm0-7a3 3 0 1 1 0-6 3 3 0 0 1 0 6z" />
                                </svg>
                                Unit #@property.UnitNumber
                            </div>

                            <div class="property-card-name">@property.Property_Name</div>

                            <div class="property-card-meta">
                                <span><img src="/images/icons/Beds.png" class="meta-icon" /> @property.BedNum Beds</span>
                                <span><img src="/images/icons/Baths.png" class="meta-icon" /> @property.BathNum Baths</span>
                                <span><img src="/images/icons/Guests.png" class="meta-icon" /> @property.GuestCapacity Guests</span>
                            </div>

                            <div class="property-card-footer">
                                <div class="property-card-rating">
                                    <span class="star">★</span>
                                    @averageRating.ToString("0.0")
                                    <span style="color:#aaa;font-weight:400">(@reviewCount)</span>
                                </div>

                                <div class="property-card-price">
                                    ₱@property.Amount.ToString("N0") <span>/night</span>
                                </div>
                            </div>
                        </div>
                    </a>
                }
            }
            else
            {
                <div class="property-card">
                    <div class="property-card-body">
                        <div class="property-card-name">No properties available yet.</div>
                        <div class="property-card-location">
                            Properties added by the admin will appear here.
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>

    <!-- Right: Recent Bookings -->
    <div>
        <h2 class="dash-section-title">Recent Bookings</h2>

        <div class="bookings-list">
            @if (recentBookings != null && recentBookings.Any())
            {
                foreach (var booking in recentBookings)
                {
                    <a href="/my-bookings" class="booking-card" style="text-decoration:none; color:inherit;">
                        <div class="booking-card-img">
                            <img src="@(string.IsNullOrWhiteSpace(booking.Property?.PropertyImagePath) ? "/images/bg-login.png" : booking.Property.PropertyImagePath)"
                                 alt="@booking.Property?.Property_Name" />
                        </div>

                        <div class="booking-card-body">
                            <div class="booking-card-name">@booking.Property?.Property_Name</div>

                            <div class="booking-card-dates">
                                @booking.CheckInDate.ToString("yyyy-MM-dd") — @booking.CheckOutDate.ToString("yyyy-MM-dd")
                            </div>

                            <div class="booking-card-price">₱@booking.TotalAmount.ToString("N0")</div>

                            <span class="booking-card-status confirmed">@booking.Status</span>
                        </div>
                    </a>
                }
            }
            else
            {
                <div class="booking-card">
                    <div class="booking-card-body">
                        <div class="booking-card-name">No recent bookings yet.</div>
                        <div class="booking-card-dates">
                            Your bookings will appear here after you reserve a property.
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>

</div>