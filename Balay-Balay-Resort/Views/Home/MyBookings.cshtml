@model Balay_Balay_Resort.ViewModels.MyBookingsViewModel
@using Balay_Balay_Resort.Models

@{
    ViewData["Title"] = "My Bookings & Transactions";
    Layout = "_DashboardLayout";

    var bookings = (Model.Bookings ?? new List<Booking>())
        .OrderByDescending(b => b.Booking_ID)
        .ToList();

    var transactions = (Model.Transactions ?? new List<Transaction>())
        .ToList();

    var transactionLookup = transactions
        .GroupBy(t => t.Booking_ID)
        .ToDictionary(
            g => g.Key,
            g => g.OrderByDescending(t => t.Transaction_ID).First()
        );
}

<div class="mybookings-wrapper">

    <!-- Search Bar -->
    <form method="get" action="/my-bookings" class="mybookings-search-bar">
        <div class="mybookings-search-input-wrap">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor"
                 viewBox="0 0 16 16" class="mybookings-search-icon">
                <path d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398h-.001c.03.04.062.078.098.115l3.85 3.85a1 1 0 0 0 1.415-1.414l-3.85-3.85a1.007 1.007 0 0 0-.115-.099zm-5.242 1.656a5.5 5.5 0 1 1 0-11 5.5 5.5 0 0 1 0 11z" />
            </svg>

            <input type="text"
                   name="search"
                   class="mybookings-search-input"
                   placeholder="Search Bookings &amp; Transaction"
                   value="@Model.SearchQuery" />
        </div>

        <button type="submit" class="mybookings-filter-btn" title="Search">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                <path d="M1.5 1.5A.5.5 0 0 1 2 1h12a.5.5 0 0 1 .5.5v2a.5.5 0 0 1-.128.334L10 8.692V13.5a.5.5 0 0 1-.342.474l-3 1A.5.5 0 0 1 6 14.5V8.692L1.628 3.834A.5.5 0 0 1 1.5 3.5v-2z" />
            </svg>
        </button>
    </form>

    <!-- Headings -->
    <div class="mybookings-paired-headings">
        <h2 class="mybookings-col-title">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                <path d="M3.5 0a.5.5 0 0 1 .5.5V1h8V.5a.5.5 0 0 1 1 0V1h1a2 2 0 0 1 2 2v11a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2V3a2 2 0 0 1 2-2h1V.5a.5.5 0 0 1 .5-.5zM1 4v10a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1V4H1z" />
            </svg>
            My Bookings
        </h2>

        <h2 class="mybookings-col-title">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                <path d="M0 4a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2V4zm2-1a1 1 0 0 0-1 1v1h14V4a1 1 0 0 0-1-1H2zm13 4H1v5a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1V7z" />
                <path d="M2 10a1 1 0 0 1 1-1h1a1 1 0 0 1 1 1v1a1 1 0 0 1-1 1H3a1 1 0 0 1-1-1v-1z" />
            </svg>
            Transaction History
        </h2>
    </div>

    <!-- Paired Booking + Transaction Rows -->
    <div class="mybookings-paired-list">

        @if (!bookings.Any())
        {
            <p class="mybookings-empty">No bookings found.</p>
        }
        else
        {
            foreach (var booking in bookings)
            {
                transactionLookup.TryGetValue(booking.Booking_ID, out var txn);

                var propertyName = booking.Property?.Property_Name ?? "Unit unavailable";
                var bookingStatus = string.IsNullOrWhiteSpace(booking.Status) ? "Pending" : booking.Status;
                var bookingStatusClass = bookingStatus.ToLower().Replace(" ", "-");

                var paymentMethod = txn?.PaymentMode ?? booking.Transaction?.PaymentMode ?? "N/A";

                var txnStatus = txn?.Status ?? "Pending";
                var txnStatusClass = txnStatus.ToLower().Replace(" ", "-");
                var txnPaymentMode = txn?.PaymentMode ?? "N/A";
                var txnReference = txn?.ReferenceNum ?? "N/A";
                var txnDate = txn != null ? txn.Date.ToString("yyyy-MM-dd") : "N/A";
                var txnTotal = txn != null ? booking.TotalAmount : 0;

                <div class="booking-transaction-row">

                    <!-- LEFT: Booking Card -->
                    <div class="paired-col">
                        <div class="mybooking-card paired-card">
                            <div class="mybooking-card-header">
                                <span class="mybooking-card-name">@propertyName</span>
                                <span class="mybooking-status @bookingStatusClass">@bookingStatus</span>
                            </div>

                            <div class="mybooking-card-id">Booking ID: BK@(booking.Booking_ID.ToString("D3"))</div>

                            <div class="mybooking-card-info">
                                <div>
                                    @booking.CheckInDate.ToString("yyyy-MM-dd")
                                    &ndash;
                                    @booking.CheckOutDate.ToString("yyyy-MM-dd")
                                </div>

                                <div>@booking.NumberOfGuest guest@(booking.NumberOfGuest == 1 ? "" : "s")</div>

                                <div>@paymentMethod</div>
                            </div>

                            <hr class="mybooking-divider" />

                            <div class="mybooking-total-row">
                                <span class="mybooking-total-label">Total Amount</span>
                                <span class="mybooking-total-amount">&#8369;@booking.TotalAmount.ToString("N0")</span>
                            </div>

                            @if (!string.Equals(booking.Status, "Cancelled", StringComparison.OrdinalIgnoreCase))
                            {
                                <form method="post"
                                      action="/booking/@booking.Booking_ID/cancel"
                                      class="cancel-booking-form">
                                    @Html.AntiForgeryToken()

                                    <button type="submit" class="mybooking-cancel-btn">
                                        Cancel Booking
                                    </button>
                                </form>
                            }
                        </div>
                    </div>

                    <!-- RIGHT: Transaction Card -->
                    <div class="paired-col">
                        <div class="txn-card paired-card">
                            <div class="txn-card-header">
                                <span class="txn-card-id">
                                    Transaction @(txn != null ? "TXN" + txn.Transaction_ID.ToString("D3") : "N/A")
                                </span>

                                <span class="mybooking-status @txnStatusClass">@txnStatus</span>
                            </div>

                            <div class="txn-card-booking-id">Booking ID: BK@(booking.Booking_ID.ToString("D3"))</div>

                            <div class="txn-card-rows">
                                <div class="txn-card-row">
                                    <span class="txn-row-label">Payment Method</span>
                                    <span class="txn-row-value">@txnPaymentMode</span>
                                </div>

                                <div class="txn-card-row">
                                    <span class="txn-row-label">Date</span>
                                    <span class="txn-row-value">@txnDate</span>
                                </div>

                                <div class="txn-card-row">
                                    <span class="txn-row-label">Reference</span>
                                    <span class="txn-row-value">@txnReference</span>
                                </div>
                            </div>

                            <hr class="txn-divider" />

                            <div class="mybooking-total-row">
                                <span class="mybooking-total-label">Total</span>
                                <span class="mybooking-total-amount">&#8369;@txnTotal.ToString("N0")</span>
                            </div>
                        </div>
                    </div>

                </div>
            }
        }

    </div>
</div>